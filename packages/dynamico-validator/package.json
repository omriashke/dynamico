{
  "name": "@omriashke/dynamico-validator",
  "version": "0.1.11",
  "description": "Server-side validator for Dynamico components. Automatically renders each pushed component with default props and book.config.json previews (with providers) in a worker thread; rejects pushes that throw or miss scope bindings.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mocks/react-native": {
      "types": "./dist/mocks/react-native.d.ts",
      "import": "./dist/mocks/react-native.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/omriaskenazi/dynamico.git",
    "directory": "packages/dynamico-validator"
  },
  "homepage": "https://github.com/omriaskenazi/dynamico#readme",
  "keywords": [
    "dynamico",
    "validator",
    "react-native",
    "push-gate"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@omriashke/dynamico-core": "workspace:*",
    "react": "^19.0.0",
    "react-test-renderer": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-test-renderer": "^18.3.0",
    "typescript": "^5.6.3"
  }
}
