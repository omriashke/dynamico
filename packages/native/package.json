{
  "name": "@dynamico/native",
  "version": "0.0.0",
  "description": "Dynamico runtime for React Native / Expo: Provider, DynamicComponent, and the native default scope.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json -w"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": "*"
  },
  "dependencies": {
    "@dynamico/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.6.3"
  }
}
