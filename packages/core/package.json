{
  "name": "@omriashke/dynamico-core",
  "version": "0.1.4",
  "description": "Renderer-agnostic core for dynamico: source adapters, module loader, versioned component registry.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/omriaskenazi/dynamico.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/omriaskenazi/dynamico#readme",
  "keywords": [
    "react",
    "runtime",
    "hot-swap",
    "dynamic-components",
    "dynamico"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json -w"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^19.0.0",
    "typescript": "^5.6.3"
  }
}
