{
  "name": "@omriashke/dynamico-registry",
  "version": "0.1.9",
  "description": "Reference registry for dynamico: compiles tsx, stores versions, broadcasts updates over WebSocket.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "dynamico-registry": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compile": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/omriaskenazi/dynamico.git",
    "directory": "packages/registry-server"
  },
  "homepage": "https://github.com/omriaskenazi/dynamico#readme",
  "keywords": [
    "react",
    "runtime",
    "dynamic-components",
    "dynamico",
    "registry",
    "server"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/bin.ts",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.0.1",
    "@omriashke/dynamico-core": "workspace:*",
    "@omriashke/dynamico-validator": "workspace:*",
    "chokidar": "^4.0.3",
    "esbuild": "^0.25.0",
    "fastify": "^5.0.0",
    "libphonenumber-js": "^1.13.6",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0"
  }
}
