{
  "name": "@dynamico/registry-server",
  "version": "0.0.0",
  "description": "Reference registry for dynamico: compiles tsx, stores versions, broadcasts updates over WebSocket.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
    "dynamico-registry": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compile": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/bin.ts",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@dynamico/core": "workspace:*",
    "@fastify/websocket": "^11.0.1",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
