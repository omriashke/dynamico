{
  "name": "@dynamico/cli",
  "version": "0.1.0",
  "description": "CLI for dynamico: push, pull, list, search, edit, and remove components from a live registry.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/bin.js",
  "types": "./dist/bin.d.ts",
  "bin": {
    "dynamico": "./dist/bin.js"
  },
  "files": ["dist", "src", "skill"],
  "repository": {
    "type": "git",
    "url": "https://github.com/omriaskenazi/dynamico.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/omriaskenazi/dynamico#readme",
  "keywords": ["react", "runtime", "dynamic-components", "dynamico", "cli"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/bin.ts"
  },
  "dependencies": {
    "@dynamico/core": "workspace:*",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
