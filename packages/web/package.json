{
  "name": "@dynamico/web",
  "version": "0.1.0",
  "description": "Dynamico runtime for React DOM: Provider, DynamicComponent, and the web default scope.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "repository": {
    "type": "git",
    "url": "https://github.com/omriaskenazi/dynamico.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/omriaskenazi/dynamico#readme",
  "keywords": ["react", "runtime", "hot-swap", "dynamic-components", "dynamico", "web"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json -w"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@dynamico/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.3"
  }
}
