{
  "name": "@omriashke/dynamico-book",
  "version": "0.1.4",
  "description": "Dynamico Book — minimal live component catalog driven entirely by registry book.config.json",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./styles.css": "./src/styles/book.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "bin": {
    "dynamico-book": "./dist/server/bin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omriashke/dynamico.git",
    "directory": "packages/book"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "dev": "tsc -p tsconfig.json -w",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "peerDependencies": {
    "@omriashke/dynamico-web": ">=0.1.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@fastify/static": "^8.1.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@omriashke/dynamico-web": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
